[
  {
    "id": 1,
    "lines": [
      "I cannot be seen",
      "Under roof or tree,",
      "Yet all the world",
      "Is seen by me.",
      "What am I?"
    ]
  },
  {
    "id": 2,
    "lines": [
      "I move on blue,",
      "On brown I stop.",
      "When wind blows hard,",
      "I'm white on top.",
      "What am I?"
    ]
  },
  {
    "id": 3,
    "lines": [
      "The closer you come,",
      "The smaller I get.",
      "'Til finally I,",
      "Am no longer wet.",
      "What am I?"
    ]
  },
  {
    "id": 4,
    "lines": [
      "Silver jaws,",
      "That close and lock.",
      "Biting teeth,",
      "That never talk.",
      "What am I?"
    ]
  },
  {
    "id": 5,
    "lines": [
      "When sadness comes,",
      "When joy is near,",
      "When hate is stirred,",
      "I may appear.",
      "What am I?"
    ]
  },
  {
    "id": 6,
    "lines": [
      "Clear as air,",
      "Smooth as ice.",
      "Born again,",
      "Heated twice.",
      "What am I?"
    ]
  },
  {
    "id": 7,
    "lines": [
      "Silent, it flies,",
      "Head white as snow.",
      "Fearful, the cries,",
      "Of those who don't know.",
      "What am I?"
    ]
  },
  {
    "id": 8,
    "lines": [
      "Skin of red,",
      "And spine of white.",
      "Future sons,",
      "In open sight.",
      "What am I?"
    ]
  },
  {
    "id": 9,
    "lines": [
      "I am the clothes,",
      "That disappear.",
      "When new I'm white,",
      "When old I'm clear.",
      "What am I?"
    ]
  },
  {
    "id": 10,
    "lines": [
      "Heart in fire,",
      "Head in ice,",
      "Home in blackness,",
      "Path precise.",
      "What am I?"
    ]
  },
  {
    "id": 11,
    "lines": [
      "My top is old,",
      "My bottom young.",
      "From water grown,",
      "From ceiling hung.",
      "What am I?"
    ]
  },
  {
    "id": 12,
    "lines": [
      "I am always getting smaller,",
      "I am always moving on.",
      "I am always being followed,",
      "When you reach me I am gone.",
      "What am I?"
    ]
  },
  {
    "id": 13,
    "lines": [
      "Born on a tree,",
      "Black or green.",
      "I'm crushed and mushed,",
      "'til I'm pure and clean.",
      "On water I float free,",
      "But fire feeds on me.",
      "What am I?"
    ]
  },
  {
    "id": 14,
    "lines": [
      "Four faces have I,",
      "I turn then I fall,",
      "Call out a letter,",
      "Then lose, split, or take all.",
      "What am I?"
    ]
  },
  {
    "id": 15,
    "lines": [
      "Mashed, chopped, sizzled, and dripping,",
      "Before I am done I need flipping.",
      "What am I?"
    ]
  },
  {
    "id": 16,
    "lines": [
      "Green or grey,",
      "Brown or blue.",
      "Windows or shades,",
      "They come in two.",
      "What are they?"
    ]
  },
  {
    "id": 17,
    "lines": [
      "An itch, a twitch,",
      "a gasp, and a blast.",
      "You did get rid of a pest,",
      "So I guess you must be blessed.",
      "What is it?"
    ]
  },
  {
    "id": 18,
    "lines": [
      "Born to roam",
      "Away from home,",
      "When old I leap",
      "Up hurdles steep,",
      "Then dying laid",
      "Upon my bed,",
      "I leave behind",
      "New life instead.",
      "What am I?"
    ]
  },
  {
    "id": 19,
    "lines": [
      "Dark and deep,",
      "Home of lights.",
      "Seen the best,",
      "On summer nights.",
      "What am I?"
    ]
  },
  {
    "id": 20,
    "lines": [
      "I'm a treasure box,",
      "Of golden chips.",
      "Soon after it's light,",
      "I'm turned upside-down,",
      "Then drenched in white,",
      "And brought to your lips.",
      "What am I?"
    ]
  }
]
