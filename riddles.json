[
  {
    "id": 1,
    "lines": [
      "I cannot be seen",
      "Under roof or tree,",
      "Yet all the world",
      "Is seen by me.",
      "What am I?"
    ]
  },
  {
    "id": 2,
    "lines": [
      "I move on blue,",
      "On brown I stop.",
      "When wind blows hard,",
      "I'm white on top.",
      "What am I?"
    ]
  },
  {
    "id": 3,
    "lines": [
      "The closer you come,",
      "The smaller I get.",
      "'Til finally I,",
      "Am no longer wet.",
      "What am I?"
    ]
  },
  {
    "id": 4,
    "lines": [
      "Silver jaws,",
      "That close and lock.",
      "Biting teeth,",
      "That never talk.",
      "What am I?"
    ]
  },
  {
    "id": 5,
    "lines": [
      "When sadness comes,",
      "When joy is near,",
      "When hate is stirred,",
      "I may appear.",
      "What am I?"
    ]
  },
  {
    "id": 6,
    "lines": [
      "Clear as air,",
      "Smooth as ice.",
      "Born again,",
      "Heated twice.",
      "What am I?"
    ]
  },
  {
    "id": 7,
    "lines": [
      "Silent, it flies,",
      "Head white as snow.",
      "Fearful, the cries,",
      "Of those who don't know.",
      "What am I?"
    ]
  },
  {
    "id": 8,
    "lines": [
      "Skin of red,",
      "And spine of white.",
      "Future sons,",
      "In open sight.",
      "What am I?"
    ]
  },
  {
    "id": 9,
    "lines": [
      "I am the clothes,",
      "That disappear.",
      "When new I'm white,",
      "When old I'm clear.",
      "What am I?"
    ]
  },
  {
    "id": 10,
    "lines": [
      "Heart in fire,",
      "Head in ice,",
      "Home in blackness,",
      "Path precise.",
      "What am I?"
    ]
  },
  {
    "id": 11,
    "lines": [
      "My top is old,",
      "My bottom young.",
      "From water grown,",
      "From ceiling hung.",
      "What am I?"
    ]
  },
  {
    "id": 12,
    "lines": [
      "I am always getting smaller,",
      "I am always moving on.",
      "I am always being followed,",
      "When you reach me I am gone.",
      "What am I?"
    ]
  },
  {
    "id": 13,
    "lines": [
      "Born on a tree,",
      "Black or green.",
      "I'm crushed and mushed,",
      "'til I'm pure and clean.",
      "On water I float free,",
      "But fire feeds on me.",
      "What am I?"
    ]
  },
  {
    "id": 14,
    "lines": [
      "Four faces have I,",
      "I turn then I fall,",
      "Call out a letter,",
      "Then lose, split, or take all.",
      "What am I?"
    ]
  },
  {
    "id": 15,
    "lines": [
      "Mashed, chopped, sizzled, and dripping,",
      "Before I am done I need flipping.",
      "What am I?"
    ]
  },
  {
    "id": 16,
    "lines": [
      "Green or grey,",
      "Brown or blue.",
      "Windows or shades,",
      "They come in two.",
      "What are they?"
    ]
  },
  {
    "id": 17,
    "lines": [
      "An itch, a twitch,",
      "a gasp, and a blast.",
      "You did get rid of a pest,",
      "So I guess you must be blessed.",
      "What is it?"
    ]
  },
  {
    "id": 18,
    "lines": [
      "Born to roam",
      "Away from home,",
      "When old I leap",
      "Up hurdles steep,",
      "Then dying laid",
      "Upon my bed,",
      "I leave behind",
      "New life instead.",
      "What am I?"
    ]
  },
  {
    "id": 19,
    "lines": [
      "Dark and deep,",
      "Home of lights.",
      "Seen the best,",
      "On summer nights.",
      "What am I?"
    ]
  },
  {
    "id": 20,
    "lines": [
      "I'm a treasure box,",
      "Of golden chips.",
      "Soon after it's light,",
      "I'm turned upside-down,",
      "Then drenched in white,",
      "And brought to your lips.",
      "What am I?"
    ]
  },
  {
    "id": 21,
    "lines": [
      "If you pass by me,",
      "You must watch where you walk.",
      "I'm a mouth in disguise,",
      "Yet I do not talk.",
      "What am I?"
    ]
  },
  {
    "id": 22,
    "lines": [
      "Round and round,",
      "Across the land.",
      "I move with speed,",
      "A killing hand.",
      "What am I?"
    ]
  },
  {
    "id": 23,
    "lines": [
      "I run along a living wall.",
      "I run as long as you are tall.",
      "Some say I am the thicker water.",
      "I give life,",
      "I burn hotter.",
      "What am I?"
    ]
  },
  {
    "id": 24,
    "lines": [
      "Double limbs,",
      "And double eyes,",
      "The trap I lay,",
      "Is home in guise.",
      "What am I?"
    ]
  },
  {
    "id": 25,
    "lines": [
      "I have no arrows,",
      "I am not crossed,",
      "My colours win,",
      "When dark has lost.",
      "What am I?"
    ]
  },
  {
    "id": 26,
    "lines": [
      "My lunar eyes,",
      "Through night do shine.",
      "It has been said,",
      "My count is nine.",
      "What am I?"
    ]
  },
  {
    "id": 27,
    "lines": [
      "I am made in fire,",
      "I am for fire made.",
      "If I am what you desire,",
      "Then you must have my aid.",
      "What am I?"
    ]
  },
  {
    "id": 28,
    "lines": [
      "I see through mountains,",
      "I feel through night.",
      "I hear the silence,",
      "I shed the light.",
      "What am I?"
    ]
  },
  {
    "id": 29,
    "lines": [
      "An ocean dry,",
      "Dead and vast.",
      "When night has come,",
      "I'm cold at last.",
      "What am I?"
    ]
  },
  {
    "id": 30,
    "lines": [
      "On face of blue,",
      "A mountain peak.",
      "In storm, a place,",
      "That you will seek.",
      "What am I?"
    ]
  },
  {
    "id": 31,
    "lines": [
      "My circle is the quickest,",
      "My silver travels fast.",
      "Of nine I look the hottest,",
      "I shrink when heat has passed.",
      "What am I?"
    ]
  },
  {
    "id": 32,
    "lines": [
      "I am the ancient dragon,",
      "Whose sleep is long and sound.",
      "Yet when I have awoken,",
      "My wrath doth know no bound.",
      "What am I?"
    ]
  },
  {
    "id": 33,
    "lines": [
      "I am a door, whose locks are two.",
      "The first was there, when second grew.",
      "Out comes sound,",
      "In goes water,",
      "Inward wind,",
      "Comes outward hotter.",
      "What am I?"
    ]
  },
  {
    "id": 34,
    "lines": [
      "Around my face,",
      "My hands do run.",
      "My will once bent,",
      "By blazing sun.",
      "What am I?"
    ]
  },
  {
    "id": 35,
    "lines": [
      "My road looks straight,",
      "Though truly round.",
      "I point to where,",
      "Lost light is found.",
      "What am I?"
    ]
  },
  {
    "id": 36,
    "lines": [
      "Shells of pink,",
      "With crowns of white,",
      "Half on left,",
      "And half on right.",
      "What are they?"
    ]
  },
  {
    "id": 37,
    "lines": [
      "I am the fastest broken,",
      "I am the first of three.",
      "When sleeping eyes are woken,",
      "It's wise to think of me.",
      "What am I?"
    ]
  },
  {
    "id": 38,
    "lines": [
      "I thrive by night,",
      "And stalk behind.",
      "I'm kept alive,",
      "By roving mind.",
      "I come before,",
      "The future foe,",
      "So much the more,",
      "The less you know.",
      "What am I?"
    ]
  },
  {
    "id": 39,
    "lines": [
      "In a book, but not read,",
      "No mind, but has a head.",
      "Struck, but not bruised,",
      "But once is it used.",
      "What am I?"
    ]
  },
  {
    "id": 40,
    "lines": [
      "White as a ghost,",
      "About ghosts I am told,",
      "I soon become gold.",
      "I just might explode,",
      "So best take me back,",
      "Before I get black.",
      "What am I?"
    ]
  }
]
